import pandas as pd
import matplotlib.pyplot as plt
from statsmodels.tsa.arima.model import ARIMA
from prophet import Prophet

# -----------------------------
# Load Dataset
# -----------------------------
df = pd.read_csv("./dataset/network_traffic.csv")

df["timestamp"] = pd.to_datetime(df["timestamp"])
df = df.sort_values("timestamp")
df.set_index("timestamp", inplace=True)

# -----------------------------
# ARIMA Forecasting
# -----------------------------
traffic_series = df["packet_count"]

model = ARIMA(traffic_series, order=(2, 1, 2))
arima_model = model.fit()

forecast_steps = 10
arima_forecast = arima_model.forecast(steps=forecast_steps)

# Create future timestamps
future_time = pd.date_range(
    start=df.index[-1],
    periods=forecast_steps + 1,
    freq="H"
)[1:]

# -----------------------------
# DDoS Detection Threshold
# -----------------------------
threshold = traffic_series.mean() + 2 * traffic_series.std()

print("DDoS Threshold:", threshold)

print("\nARIMA Forecast Result:")
for time, value in zip(future_time, arima_forecast):
    status = "Possible DDoS Attack" if value > threshold else "Normal Traffic"
    print(time, int(value), status)

# -----------------------------
# Plot ARIMA Result
# -----------------------------
plt.figure(figsize=(10, 5))
plt.plot(df.index, df["packet_count"], label="Historical Traffic")
plt.plot(future_time, arima_forecast, label="ARIMA Forecast")
plt.axhline(y=threshold, linestyle="--", label="DDoS Threshold")
plt.xlabel("Time")
plt.ylabel("Packet Count")
plt.title("DDoS Prediction using ARIMA")
plt.legend()
plt.show()

# -----------------------------
# Prophet Forecasting
# -----------------------------
prophet_df = df.reset_index()
prophet_df = prophet_df.rename(columns={
    "timestamp": "ds",
    "packet_count": "y"
})

prophet_model = Prophet()
prophet_model.fit(prophet_df)

future = prophet_model.make_future_dataframe(periods=10, freq="H")
forecast = prophet_model.predict(future)

# -----------------------------
# Prophet DDoS Detection
# -----------------------------
print("\nProphet Forecast Result:")
future_forecast = forecast.tail(10)

for _, row in future_forecast.iterrows():
    status = "Possible DDoS Attack" if row["yhat"] > threshold else "Normal Traffic"
    print(row["ds"], int(row["yhat"]), status)

# -----------------------------
# Plot Prophet Result
# -----------------------------
fig = prophet_model.plot(forecast)
plt.axhline(y=threshold, linestyle="--", label="DDoS Threshold")
plt.title("DDoS Prediction using Prophet")
plt.legend()
plt.show()
